# Socratic Approach - Environment Variables

# Required: OpenRouter API Key
# Get yours from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Required for history storage: Neon Database URL
# Get yours from https://neon.tech/
# Format: postgres://user:password@host.neon.tech/dbname
NEON_DATABASE_URL=postgres://user:password@host.neon.tech/dbname

# Alternatively, you can use DATABASE_URL instead of NEON_DATABASE_URL
# DATABASE_URL=postgres://user:password@host.neon.tech/dbname

# Optional: Server port (default: 3000)
PORT=3000
